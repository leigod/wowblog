# ==========================================
# WowBlog 后端环境变量配置模板
# ==========================================
# 复制此文件为 .env 并填入实际值
# 警告：.env 文件包含敏感信息，请勿提交到版本控制系统

# ==========================================
# 数据库配置
# ==========================================
# 数据库连接URL（必须）
DATABASE_URL=mysql+aiomysql://username:password@localhost:8889/wowblog
# 或分开配置（可选，当DATABASE_URL未设置时使用）
DATABASE_HOST=localhost
DATABASE_PORT=8889
DATABASE_NAME=wowblog
DATABASE_USER=root
DATABASE_PASSWORD=your_password_here

# MySQL Root 密码（仅用于 Docker Compose）
MYSQL_ROOT_PASSWORD=your_root_password_here

# ==========================================
# JWT配置
# ==========================================
# JWT密钥（必须）- 使用强随机字符串
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here_generate_with_openssl_or_python

# 访问令牌有效期（分钟）
# 生产环境推荐：30
# 开发环境可以设置更长
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# 环境配置
# ==========================================
# 环境类型：production 或 development
ENVIRONMENT=development

# 调试模式：true 或 false
# 生产环境必须设置为 false
DEBUG=false

# 允许的CORS源（逗号分隔）
# 生产环境设置实际域名
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5177

# ==========================================
# OAuth配置（可选）
# ==========================================
# Apple OAuth配置
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ==========================================
# Redis 配置（可选，用于缓存和会话）
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# 邮件配置（可选）
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# ==========================================
# 文件上传配置
# ==========================================
# 最大上传大小（MB）
MAX_UPLOAD_SIZE=10
# 允许的文件类型
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
LOG_FILE_PATH=app/logs/app.log

# ==========================================
# 站点信息
# ==========================================
SITE_NAME=WowBlog
SITE_URL=https://yourdomain.com
ADMIN_EMAIL=admin@example.com
TIMEZONE=Asia/Shanghai

# ==========================================
# 站点 URL（用于 OAuth 回调 / 邮件链接等）
# ==========================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000/api

# ==========================================
# 成员管理
# ==========================================
# 管理后台新建成员的默认密码（首次登录后应修改）
DEFAULT_MEMBER_PASSWORD=changeme123

# ==========================================
# 可选配置
# ==========================================
# 服务器端口（默认由uvicorn配置）
# PORT=8000

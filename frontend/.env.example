# ==========================================
# CMS Site 前端环境变量配置模板
# ==========================================
# 复制此文件为 .env.local 并填入实际值
# 注意：所有环境变量必须以 VITE_ 前缀开头才能在客户端代码中访问

# ==========================================
# API配置
# ==========================================
# API基础URL（必须）
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# ==========================================
# 应用配置
# ==========================================
# 应用名称
VITE_APP_NAME=CMS站点

# 调试模式
VITE_DEBUG_MODE=false

# ==========================================
# 可选配置
# ==========================================
# 上传文件大小限制（MB）
VITE_MAX_FILE_SIZE=10

# 支持的图片格式
VITE_ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# 分页大小
VITE_PAGE_SIZE=20

# ==========================================
# 开发环境
# ==========================================
# 开发服务器端口
# VITE_DEV_PORT=5173
